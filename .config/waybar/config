{
    "reload_style_on_change": true,
    "layer": "top",
    "position": "top",
    "height": 36,
    "margin-top": 4,
    "margin-left": 4,
    "margin-right": 4,
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-center": [
      "hyprland/window"
    ],
    "modules-right": [
      "tray",
      "hyprland/language",
      "pulseaudio",
      "backlight",
      "power-profiles-daemon",
      "battery",
      "bluetooth",
      "network",
      "clock"
    ],
    "hyprland/window": {
      "separate-outputs": true,
      "tooltip": false,
      "max-length": 64
    },
    "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "on-click": "activate",
      "format": "{icon}",
      "format-icons": {
        "active": "ΎΗΤ",
        "default": "ΎΤς"
      },
      "persistent-workspaces": {
        "*": [ 1, 2, 3, 4 ]
      }
    },
    "tray": {
      "icon-size": 21,
      "spacing": 10
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "Ό╗ρ ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "default": ["ΎΑο   ", "ΎΑπ  ", "ΎΑρ "]
        },
        "tooltip-format": "{volume}%",
        "on-click": "$TERMINAL start -e wiremix"
    },
    "hyprland/language": {
        "format": "ΎΕε {}",
        "format-en": "QWERTY",
        "format-en-colemak_dh": "Colemak-DH",
        "format-tr": "As bayraklar─▒",
        "keyboard-name": "at-translated-set-2-keyboard"
    },
    "backlight": {
        "format": "{icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
        "tooltip-format": "{percent}%",
        "on-click": "hyprsunset-toggle"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip": true,
      "tooltip-format": "Power profile: {profile}",
      "format-icons": {
        "default": "ΎΔπ",
        "performance": "ΎΔπ",
        "balanced": "ΎΚΟ",
        "power-saver": "ΎΒυ"
      }
    },
    "battery": {
      "states": {
        "warning": 15,
        "critical": 5
      },
      "format": "ΎΔπ",
      "format-discharging": "{icon}",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
      "tooltip-format": "{capacity}% | {timeTo}"
    },
    "bluetooth": {
    	"format": "≤░Γψ",
    	"format-disabled": "≤░Γ▓",
    	"format-connected": "≤░Γ▒",
    	"tooltip-format-connected": "{device_alias} {device_battery_percentage}%",
      "on-click": "vicinae vicinae://launch/@Gelei/store.vicinae.bluetooth"
    },
    "network": {
      "format": "{icon}",
      "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
      "format-disconnected": "≤░νφ",
      "format-ethernet": "ΎΔΒ",
      "tooltip-format-wifi": "{essid} | {signalStrength}%",
      "tooltip-format-ethernet": "{ifname}",
      "on-click": "vicinae vicinae://launch/@dagimg-dot/store.vicinae.wifi-commander"
    },
    "clock": {
      "format": "{:%H:%M}",
      "tooltip-format": "{:%A, %B %d, %Y}",
    }
}
