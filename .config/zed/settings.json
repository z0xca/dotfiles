// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "language_models": {
    "ollama": {
      "api_url": "http://10.0.0.5:11434",
    },
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "ollama",
    "ollama": {
      "model": "gpt-oss:20b",
      "api_url": "http://10.0.0.5:11434",
    },
  },
  "outline_panel": {
    "dock": "left",
  },
  "agent": {
    "default_profile": "ask",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow",
        },
      },
    },
    "default_model": {
      "provider": "ollama",
      "model": "gpt-oss:20b",
      "enable_thinking": true,
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "ui_font_family": "SF Pro Text",
  "buffer_font_family": "Monaspace Neon NF",
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
    },
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "tab_size": 2,
  "use_system_window_tabs": false,
  "bottom_dock_layout": "contained",
  "tabs": {
    "file_icons": false,
    "git_status": false,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_user_picture": true,
  },
  "diagnostics": {
    "button": true,
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true,
  },
  "project_panel": {
    "dock": "left",
    "button": true,
    "file_icons": true,
  },
  "terminal": {
    "cursor_shape": "bar",
    "shell": "system",
    "button": true,
    "font_family": "SF Mono",
  },
  "disable_ai": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": false,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Matugen Dark",
    "dark": "Matugen Dark",
  },
  "context_servers": {},
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
        "experimental": {
          "classRegex": ["[cls|className]\\s\\:\\=\\s\"([^\"]*)"],
        },
      },
    },
    "nixd": {
      "initialization_options": {
        "formatting": {
          "command": ["alejandra"],
        },
      },
    },
  },
  "format_on_save": "on",
  "languages": {
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": {
        "external": {
          "command": "alejandra",
        },
      },
    },
    "Markdown": {
      "language_servers": ["rumdl"],
    },
    "Astro": {
      "formatter": "prettier",
    },
    "JavaScript": {
      "formatter": "prettier",
    },
    "TypeScript": {
      "formatter": "prettier",
    },
    "TSX": {
      "formatter": "prettier",
    },
    "HTML": {
      "formatter": "prettier",
    },
    "JSON": {
      "formatter": "prettier",
    },
  },
  "file_scan_inclusions": ["example"],
}
